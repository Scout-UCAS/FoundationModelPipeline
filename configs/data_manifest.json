  "processing_stages": [
    {
      "name": "ingest_normalize",
      "operations": ["schema_mapping", "license_tagging", "language_id", "content_type_routing", "audio_decode_resample", "vad_segmentation", "hash_indexing"],
      "output": "versioned_raw_shards",
      "owner": "data-platform"
    },
    {
      "name": "clean_filter",
      "operations": ["html_boilerplate_removal", "pii_redaction", "toxicity_filtering", "low_information_filtering", "ocr_noise_repair", "audio_denoise_vad_filter"],
      "output": "clean_candidate_shards",
      "owner": "data-quality"
    },
    {
      "name": "deduplicate",
      "operations": ["exact_hash_dedup", "minhash_lsh_near_dedup", "embedding_near_dedup", "audio_fingerprint_dedup", "video_shot_dedup", "trajectory_dedup"],
      "output": "deduplicated_shards",
      "owner": "data-quality"
    },
    {
      "name": "cluster_balance",
      "operations": ["embedding_clustering", "topic_taxonomy_assignment", "domain_temperature_sampling", "language_balancing", "modality_balancing"],
      "output": "clustered_data_pool",
      "owner": "data-science"
    },
    {
      "name": "quality_assess",
      "operations": ["perplexity_quality_score", "aesthetic_score", "video_motion_score", "asr_wer_proxy", "speaker_balance_score", "instruction_following_proxy", "vla_success_proxy"],
      "output": "quality_ranked_pool",
      "owner": "model-quality"
    },
    {
      "name": "pack_shard",
      "operations": ["sequence_packing", "multimodal_sample_packing", "audio_text_sample_packing", "deterministic_sharding", "manifest_snapshot"],
      "output": "train_ready_mixture_shards",
      "owner": "data-platform"
    }
  ],
  "mixture_stages": [
    {
      "name": "warmup_2k",
      "total_tb": 150,
      "objective": "stabilize tokenizer, optimizer, and early curriculum",
      "modality_targets": {
        "pure_text": 0.69,
        "multimodal": 0.16,
        "video_pretraining": 0.08,
        "audio_speech": 0.03,
